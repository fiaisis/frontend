    "@types/node": "26.1.1",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.5",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "express": "5.2.1",
    "express-ws": "5.0.2",
    "i18next": "^26.3.6",
    "jwt-decode": "^4.0.0",
    "loglevel": "1.9.2",
    "monaco-editor": "^0.55.1",
    "ndarray": "1.0.19",
